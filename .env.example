# ============================================================
# Aeternum Hub GPU — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file
# ============================================================

# ── Twilio Configuration ─────────────────────────────────────
# Credentials for SMS and Voice alerts from Twilio

# Twilio Account SID — from twilio.com/console — Required
TWILIO_SID=your_account_sid_here

# Twilio Auth Token — from twilio.com/console — Required
TWILIO_TOKEN=your_auth_token_here

# Twilio Phone Number — purchased via Twilio — Required
FROM_NUMBER=your_twilio_number_here

# Recipient Phone Number — target for alerts — Required
TO_NUMBER=your_actual_phone_number_here

# ── System Configuration ─────────────────────────────────────
# Application server settings

# Redis URL — Connection string for Redis server — Required
REDIS_URL=redis://localhost:6379/0

# Database path for events — local sqlite storage — Optional
EVENTS_DB_PATH=backend/data/events.db
